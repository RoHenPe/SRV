# ─────────────────────────────────────────────────────────────────────────────
# ROHENPER Dashboard - Environment Variables
# ─────────────────────────────────────────────────────────────────────────────

# ─────────────────────────────────────────────────────────────────────────────
# AUTHENTICATION (NEW - REQUIRED FOR PRODUCTION)
# ─────────────────────────────────────────────────────────────────────────────

# API Key for dashboard access
# Generate a secure random string (e.g., openssl rand -base64 32)
API_KEY=your-secure-api-key-change-this

# ─────────────────────────────────────────────────────────────────────────────
# SSH SERVER CONNECTION (REQUIRED)
# ─────────────────────────────────────────────────────────────────────────────

# Primary server IP (LAN or local)
SSH_HOST=192.168.1.100

# VPN fallback IP (optional, used if SSH_HOST is unreachable)
SSH_HOST_VPN=10.0.0.100

# SSH username
SSH_USER=rodrigo

# SSH port (optional, defaults to 22)
SSH_PORT=22

# SSH authentication method - choose ONE:
#   Option 1 (RECOMMENDED): Private key in Base64
#   To generate: cat ~/.ssh/id_rsa | base64 -w 0 | xclip -selection clipboard
SSH_PRIVATE_KEY_B64=LS0tLS1CRUdJTi4uLi0tLS0t

#   Option 2: Password authentication (less secure)
#   SSH_PASSWORD=your_ssh_password

# ─────────────────────────────────────────────────────────────────────────────
# FRONTEND CONFIGURATION & TUNNELS
# ─────────────────────────────────────────────────────────────────────────────

# Server IP for quick links (Cockpit, SMB, VNC)
# If not set, defaults to SSH_HOST
# NEXT_PUBLIC_SSH_HOST=192.168.1.100

# Ngrok Authtoken (Required for HTTPS tunnels when accessing via Vercel)
# Get yours at https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=your-ngrok-authtoken-here

# ─────────────────────────────────────────────────────────────────────────────
# LOGGING
# ─────────────────────────────────────────────────────────────────────────────

# Log level: debug, info, warn, error
LOG_LEVEL=info

# ─────────────────────────────────────────────────────────────────────────────
# RATE LIMITING
# ─────────────────────────────────────────────────────────────────────────────

# Enable rate limiting (true/false)
RATE_LIMIT_ENABLED=true

# Requests per minute per IP
RATE_LIMIT_REQUESTS_PER_MIN=10

# ─────────────────────────────────────────────────────────────────────────────
# BUILD & DEPLOYMENT
# ─────────────────────────────────────────────────────────────────────────────

NODE_ENV=production
NEXT_TELEMETRY_DISABLED=1

# ─────────────────────────────────────────────────────────────────────────────
# SETUP INSTRUCTIONS
# ─────────────────────────────────────────────────────────────────────────────
#
# 1. Local Development:
#    cp .env.example .env.local
#    Fill in your SSH server details and API key
#    npm run dev
#
# 2. Vercel Deployment:
#    - Go to your Vercel project settings
#    - Environment Variables section
#    - Add each variable from this file
#    - Deploy
#
# 3. Security:
#    - NEVER commit .env to git
#    - NEVER share your API_KEY
#    - Use a unique API_KEY for each environment
#    - Rotate API_KEY periodically
#
# ─────────────────────────────────────────────────────────────────────────────
